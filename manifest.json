{
  "manifest_version": 3,
  "name": "MoxTags",
  "version": "1.0.0",
  "description": "Adds Scryfall Tagger art and card tags to Moxfield deck card menus",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "alarms"
  ],
  "host_permissions": [
    "https://api2.moxfield.com/*",
    "https://api.scryfall.com/*"
  ],
  "icons": {
    "16": "icons/moxtags-gem-16.png",
    "32": "icons/moxtags-gem-32.png",
    "48": "icons/moxtags-gem-48.png",
    "128": "icons/moxtags-gem-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://moxfield.com/decks/*",
        "https://www.moxfield.com/decks/*"
      ],
      "js": ["page_hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://moxfield.com/decks/*",
        "https://www.moxfield.com/decks/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/moxtags-gem-16.png",
      "32": "icons/moxtags-gem-32.png",
      "48": "icons/moxtags-gem-48.png",
      "128": "icons/moxtags-gem-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "MoxTags"
  }
}
